# =====================================================
# HEXLORE VPS BOT - ENVIRONMENT CONFIGURATION
# =====================================================

# DISCORD BOT SETTINGS
# Discord bot token from Developer Portal
DISCORD_TOKEN=your_bot_token_here

# Command prefix (used for prefix commands)
COMMAND_PREFIX=!

# Owner Discord ID (for owner-only commands)
OWNER_ID=your_discord_id_here

# =====================================================
# DATABASE SETTINGS
# =====================================================

# MongoDB connection URI
MONGO_URI=mongodb://localhost:27017

# MongoDB database name
MONGO_DB_NAME=hexlore_vps

# =====================================================
# DOCKER SETTINGS
# =====================================================

# Path to Docker socket
DOCKER_SOCKET=/var/run/docker.sock

# Docker registry URL
DOCKER_REGISTRY=docker.io

# Docker API base URL
DOCKER_API_BASE_URL=unix:///var/run/docker.sock

# =====================================================
# API SETTINGS
# =====================================================

# API server port
API_PORT=8000

# API server host
API_HOST=0.0.0.0

# API key length for generation
API_KEY_LENGTH=32

# =====================================================
# SECURITY SETTINGS
# =====================================================

# Encryption key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
ENCRYPTION_KEY=your_encryption_key_here

# Session timeout in seconds
SESSION_TIMEOUT=3600

# Rate limit calls per period
RATE_LIMIT_CALLS=10

# Rate limit period in seconds
RATE_LIMIT_PERIOD=60

# Max failed login attempts
MAX_LOGIN_ATTEMPTS=5

# =====================================================
# LOGGING SETTINGS
# =====================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path
LOG_FILE=logs/bot.log

# Max log file size in MB
LOG_FILE_SIZE=10

# Number of backup log files to keep
LOG_BACKUP_COUNT=5

# =====================================================
# FEATURE FLAGS
# =====================================================

# Enable premium features
ENABLE_PREMIUM=true

# Enable billing system
ENABLE_BILLING=true

# Enable auto backups
ENABLE_AUTO_BACKUPS=true

# Enable health checks
ENABLE_HEALTH_CHECKS=true

# =====================================================
# VPS LIMITS
# =====================================================

# Maximum VPS per user (free)
MAX_VPS_PER_USER=5

# Maximum VPS per user (premium)
MAX_VPS_PER_USER_PREMIUM=20

# Default container RAM in MB
DEFAULT_RAM_MB=512

# Default container CPU shares
DEFAULT_CPU_SHARES=1024

# Default container disk in GB
DEFAULT_DISK_GB=10

# =====================================================
# NODE SETTINGS
# =====================================================

# Default node host
DEFAULT_NODE_HOST=localhost

# Default node port
DEFAULT_NODE_PORT=2375

# Node health check interval (seconds)
NODE_HEALTH_CHECK_INTERVAL=300

# =====================================================
# BACKUP SETTINGS
# =====================================================

# Backup storage path
BACKUP_STORAGE_PATH=./backups

# Auto backup interval (hours)
AUTO_BACKUP_INTERVAL=24

# Max backup retention days
BACKUP_RETENTION_DAYS=30

# =====================================================
# BILLING SETTINGS
# =====================================================

# Currency code
CURRENCY=USD

# Price per GB per month
PRICE_PER_GB_MONTH=0.50

# Billing cycle days
BILLING_CYCLE_DAYS=30

# =====================================================
# MAINTENANCE
# =====================================================

# Enable maintenance mode
MAINTENANCE_MODE=false

# Maintenance message
MAINTENANCE_MESSAGE=Bot is under maintenance. Please try again later.
